    {
      "id": "envelope_load_formula",
      "name": "Envelope Heat Load",
      "category": "cooling_load",
      "type": "formula",
      "formula": "area * factor",
      "variables": { "area": 0, "factor": 120 },
      "unit": "BTU/h",
      "description": "Simplified envelope load = area × space-specific factor"
    },
    {
      "id": "people_load_formula",
      "name": "People Heat Load",
      "category": "cooling_load",
      "type": "formula",
      "formula": "occupants * btu_per_person",
      "variables": { "occupants": 0, "btu_per_person": 245 },
      "unit": "BTU/h",
      "description": "Occupant sensible heat gain"
    },
    {
      "id": "lighting_load_formula",
      "name": "Lighting Heat Load",
      "category": "cooling_load",
      "type": "formula",
      "formula": "area * density * watt_to_btu",
      "variables": { "area": 0, "density": 12, "watt_to_btu": 3.412 },
      "unit": "BTU/h",
      "description": "Lighting heat gain = area × W/m² × 3.412"
    },
    {
      "id": "equipment_load_formula",
      "name": "Equipment Heat Load",
      "category": "cooling_load",
      "type": "formula",
      "formula": "watts * watt_to_btu",
      "variables": { "watts": 0, "watt_to_btu": 3.412 },
      "unit": "BTU/h",
      "description": "Equipment heat gain = watts × 3.412"
    },
    {
      "id": "ventilation_sensible_formula",
      "name": "Ventilation Sensible Load",
      "category": "cooling_load",
      "type": "formula",
      "formula": "cfm_constant * cfm * delta_t",
      "variables": { "cfm_constant": 1.08, "cfm": 0, "delta_t": 0 },
      "unit": "BTU/h",
      "description": "Ventilation sensible load = 1.08 × CFM × ΔT(°F)"
    },
    {
      "id": "ventilation_latent_formula",
      "name": "Ventilation Latent Load",
      "category": "cooling_load",
      "type": "formula",
      "formula": "0.68 * cfm * delta_w * 7000",
      "variables": { "cfm": 0, "delta_w": 0 },
      "unit": "BTU/h",
      "description": "Ventilation latent load = 0.68 × CFM × ΔW × 7000"
    },
    {
      "id": "design_load_formula",
      "name": "Design Load with Factors",
      "category": "cooling_load",
      "type": "formula",
      "formula": "raw_total * safety_factor * diversity_factor",
      "variables": { "raw_total": 0, "safety_factor": 1.1, "diversity_factor": 0.95 },
      "unit": "BTU/h",
      "description": "Final design load = raw × safety × diversity"
    },
    {
      "id": "cfm_from_btu_formula",
      "name": "CFM from BTU Load",
      "category": "cooling_load",
      "type": "formula",
      "formula": "total_btu / (cfm_constant * supply_delta_t)",
      "variables": { "total_btu": 0, "cfm_constant": 1.08, "supply_delta_t": 20 },
      "unit": "CFM",
      "description": "Required airflow = BTU / (1.08 × supply ΔT°F)"
    },
    {
      "id": "wall_cltd_formula",
      "name": "Wall Conduction Load",
      "category": "cooling_load",
      "type": "formula",
      "formula": "u_value * wall_area * corrected_cltd",
      "variables": { "u_value": 3.42, "wall_area": 0, "corrected_cltd": 10 },
      "unit": "W",
      "description": "ASHRAE wall conduction: Q = U × A × CLTD_corrected"
    },
    {
      "id": "glass_solar_formula",
      "name": "Glass Solar Load",
      "category": "cooling_load",
      "type": "formula",
      "formula": "window_area * sc * shgf",
      "variables": { "window_area": 0, "sc": 0.95, "shgf": 300 },
      "unit": "W",
      "description": "Solar heat gain through glass: Q = A × SC × SHGF"
    }
  ]
