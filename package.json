{
  "name": "hvac-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-app.ps1",
    "dev:no-turbo": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-app.ps1 -NoTurbo",
    "dev:raw": "next dev --turbopack",
    "dev:raw:no-turbo": "next dev",
    "dev:stack": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-stack.ps1 -ReuseRunningApp -ReuseRunningEmulator",
    "dev:stack:no-turbo": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-stack.ps1 -NoTurbo -ReuseRunningApp -ReuseRunningEmulator",
    "dev:stack:reuse": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-stack.ps1 -ReuseRunningApp -ReuseRunningEmulator",
    "dev:emulator": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-with-emulator.ps1",
    "dev:emulator:no-turbo": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-with-emulator.ps1 -NoTurbo",
    "emulator:firestore": "npx firebase-tools emulators:start --only firestore --project demo-hvac-auto --config firebase.json",
    "firebase:web-key:sync": "powershell -ExecutionPolicy Bypass -File ./scripts/sync-firebase-web-key.ps1",
    "build": "next build",
    "build:netlify": "next build",
    "start": "next start",
    "lint": "eslint .",
    "audit:fix": "npm audit fix",
    "audit:check": "npm audit --audit-level=moderate",
    "clean": "Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue",
    "validate:preflight": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-preflight.ps1",
    "validate:preflight:strict": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-preflight.ps1 -RequireJava -RequireFirebaseCli -RequireWebApiKey",
    "validate:preflight:strict:local": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-preflight-strict-local.ps1",
    "auth:set-role": "tsx ./scripts/ts/set-user-role.mts",
    "seed:mock": "tsx ./scripts/ts/seed-mock-project.mts",
    "reports:backfill:legacy": "tsx ./scripts/ts/backfill-simulation-report-history.mts",
    "validate:auth": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-auth.ps1",
    "validate:auth:positive": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-auth-positive.ps1",
    "validate:rbac": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-rbac.ps1",
    "validate:rbac:positive": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-rbac-positive.ps1",
    "validate:rbac:positive:strict": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-rbac-positive.ps1 -StrictAdminPositive",
    "validate:rbac:positive:raw": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-rbac.ps1 -RequireAdminPositive",
    "validate:building-simulation": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-building-simulation.ps1",
    "validate:dual-control": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-dual-control.ps1",
    "validate:catalog:admin": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-catalog-admin.ps1",
    "validate:catalog:admin:strict": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke-catalog-admin.ps1 -Strict",
    "validate:quality": "npm run lint && npm run build && npm run audit:check",
    "validate:docx:parity": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-docx-parity.ps1",
    "validate:docx:parity:strict": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-docx-parity.ps1 -Strict",
    "validate:system": "npm run validate:preflight && npm run validate:auth && npm run validate:rbac && npm run validate:dual-control && npm run validate:building-simulation && npm run validate:catalog:admin && npm run validate:quality",
    "validate:system:strict:raw": "npm run validate:preflight:strict && npm run validate:auth:positive && npm run validate:rbac:positive:strict && npm run validate:dual-control && npm run validate:building-simulation && npm run validate:catalog:admin:strict && npm run validate:quality",
    "validate:system:strict": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-system-strict.ps1",
    "validate:system:local": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-system-local.ps1",
    "validate:system:strict:local": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-system-local.ps1 -Strict"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@netlify/next": "1.4.9",
    "@react-oauth/google": "0.13.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/pdfmake": "0.3.2",
    "@types/three": "0.179.0",
    "bcryptjs": "3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "16.6.1",
    "exceljs": "4.4.0",
    "fabric": "^7.2.0",
    "firebase": "12.12.1",
    "firebase-admin": "13.8.0",
    "framer-motion": "^12.34.3",
    "jsonwebtoken": "9.0.3",
    "lucide-react": "^0.575.0",
    "mathjs": "15.2.0",
    "next": "16.2.3",
    "pdfmake": "0.3.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "3.0.2",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "three": "0.179.1",
    "uuid": "14.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "5.15.9",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fabric": "^5.3.11",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "lodash": "4.17.23",
    "hono": "^4.12.4",
    "@hono/node-server": "^1.19.10",
    "@google-cloud/firestore": "8.5.0",
    "google-gax": "5.0.6",
    "gaxios": "7.1.4",
    "retry-request": "8.0.2",
    "teeny-request": "10.1.2",
    "postcss": "8.5.14",
    "uuid": "14.0.0"
  }
}
